<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SvgDemo.MainWindow"
        Title="Avalonia.Svg Demo"
        Width="960" Height="700">

  <Window.Styles>
    <Style Selector="TextBlock.caption">
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Foreground" Value="#475569"/>
      <Setter Property="MaxWidth" Value="820"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>
    <Style Selector="Border.canvas">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#e2e8f0"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>
  </Window.Styles>

  <TabControl Margin="8">

    <TabItem Header="Shapes">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            All basic shape elements compile into one retained DrawingRecording: rect (including rounded
            and SVG 2 rx/ry auto), circle, ellipse, line, polyline, polygon and path with the full path
            grammar (curves, arcs, even-odd fill rule). Stroke caps, joins, dash arrays, miter limits and
            paint-order are honored.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/shapes.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Gradients &amp; Patterns">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            Linear and radial gradients in objectBoundingBox or userSpaceOnUse units, with
            gradientTransform, stop-opacity and spreadMethod. The wide bottom row shares a single
            user-space gradient across three shapes. Patterns compile their tile content once into a
            shared recording and paint as a tiled brush, including patternTransform.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/gradients.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Use &amp; Markers">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            A symbol compiles once and replays at every use site under its own viewport mapping — the
            map pin is one shared recording at three sizes, and the badge group is rendered once and
            referenced twice more. Markers (arrowheads, vertex dots) replay the same way along path and
            polyline vertices, including orient="auto-start-reverse".
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/symbols.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Text">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            SVG text runs through Avalonia's full text pipeline (TextFormatter): script itemization,
            font fallback, bidi and shaping — so mixed scripts just work. Chunks anchor with
            text-anchor, tspans restyle mid-line without breaking shaping, dx/dy shift baselines, and
            textPath places glyphs along an arc-length parameterized path.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/text.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Compositing">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            Group opacity, mix-blend-mode and isolation fold into recorded layers; clip-path clips
            geometrically and mask applies a luminance mask brush (white keeps, black removes). Compare
            the two red pairs: group opacity flattens the overlap, per-shape opacity blends it.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/compositing.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Filters">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            Filters map onto recorded layer effects: feGaussianBlur, feDropShadow, feOffset and
            feColorMatrix (matrix, saturate, hueRotate), composed into sequential chains. The star uses
            the classic SourceAlpha blur + offset + feMerge pattern, which collapses into a single
            drop-shadow effect at compile time.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/filters.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Animation">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            SMIL animations run on two channels. Paint channel: color animations on a shape's own
            fill/stroke mutate brushes inside a compositor-bound recording — nothing is ever
            re-recorded. Structural channel: transforms, geometry and visibility re-compile the root
            per change tick while shared sub-recordings (like the pinwheel petal) replay from cache.
          </TextBlock>
          <TextBlock FontWeight="Bold">Paint channel — brush mutation only</TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/animation-paint.svg"/>
          </Border>
          <TextBlock FontWeight="Bold">Structural channel — re-emission over shared recordings</TextBlock>
          <Border Classes="canvas">
            <SvgControl Source="avares://SvgDemo/Assets/animation-structural.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Showcase">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            Everything at once: an animated orrery with roughly 150 elements and 18 SMIL timelines.
            The starfield replays one shared star recording per use site, the sun pulses under a
            blurred glow, moons ride nested structural rotations on top of their planets' orbits, the
            comet's elliptical path is a static squash around an animated rotate, and a label runs
            along the outer orbit on a textPath. The legend lamps show the two channels live: paint
            animations mutate compositor brushes in place, structural ones recompile the document each
            tick — for this scene that is well under a millisecond per frame.
          </TextBlock>
          <Border Classes="canvas" Background="#0b1022">
            <SvgControl Source="avares://SvgDemo/Assets/showcase.svg"/>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Inline">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            SVG markup pasted straight into the XAML — no CDATA wrapper. The compiler captures the
            &lt;svg&gt; subtree verbatim, validates it at build time (a typo here is a build error
            pointing at this file) and strips comments, editor metadata and insignificant whitespace,
            so the runtime parses a compact pre-checked string with no file or resource I/O.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Width="160" Height="160">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
                <!-- this comment never reaches the runtime -->
                <defs>
                  <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#7dd3fc"/>
                    <stop offset="1" stop-color="#0ea5e9"/>
                  </linearGradient>
                </defs>
                <rect width="64" height="64" rx="12" fill="url(#sky)"/>
                <circle cx="22" cy="22" r="8" fill="#fef9c3"/>
                <path d="M8 46 L24 30 L36 42 L46 32 L56 42 V56 H8 Z" fill="#166534"/>
                <path d="M8 50 L20 38 L30 48 L42 36 L56 50 V56 H8 Z" fill="#22c55e"/>
                <text x="32" y="61" font-size="5" text-anchor="middle" fill="#0c4a6e">inline svg</text>
              </svg>
            </SvgControl>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Interactivity">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            The compiler builds an element hit-test tree next to the recording. Move over the drawing to
            see the innermost-first event-target chain; click to log the hit. The grid ignores the
            pointer (pointer-events="none"), the purple ring hits only on its stroke band, the dashed
            rectangle is an invisible hot zone (fill="none" with pointer-events="all"), and the gears
            report the symbol content plus their use site.
          </TextBlock>
          <Border Classes="canvas">
            <SvgControl Name="InteractiveSvg" Source="avares://SvgDemo/Assets/interactive.svg"/>
          </Border>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock FontWeight="Bold" Text="Under pointer:"/>
            <TextBlock Name="HoverChainText" Foreground="#0f766e" FontFamily="Consolas,Menlo,monospace" Text="—"/>
          </StackPanel>
          <TextBlock FontWeight="Bold" Text="Clicks:"/>
          <ItemsControl Name="ClickLog" FontFamily="Consolas,Menlo,monospace" Foreground="#334155"/>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <TabItem Header="Image Source">
      <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
          <TextBlock Classes="caption">
            An SVG resolves to an SvgImage through the same IImage type converter that loads raster
            bitmaps, so it can be the Source of a plain Image control — no SvgControl required. A URI
            ending in .svg routes to the vector loader; anything else stays a raster Bitmap. Both the
            Source attribute and the element-content form work.
          </TextBlock>
          <Border Classes="canvas">
            <Image Width="200" Height="200" Source="avares://SvgDemo/Assets/shapes.svg"/>
          </Border>
          <TextBlock Classes="caption">The same converter via element content (the URI is the Image's Content):</TextBlock>
          <Border Classes="canvas">
            <Image Width="200" Height="200">avares://SvgDemo/Assets/showcase.svg</Image>
          </Border>
        </StackPanel>
      </ScrollViewer>
    </TabItem>

  </TabControl>
</Window>
