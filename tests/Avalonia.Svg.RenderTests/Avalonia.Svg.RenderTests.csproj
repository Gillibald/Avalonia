<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(AvsCurrentTargetFramework)</TargetFramework>
    <OutputType>Exe</OutputType>
  </PropertyGroup>
  <ItemGroup>
    <!-- Shared render-test infrastructure (immediate + composited rendering and
         image comparison) reused from the platform render tests. -->
    <Compile Include="..\Avalonia.RenderTests\TestRenderHelper.cs" Link="Infrastructure\TestRenderHelper.cs" />
    <Compile Include="..\Avalonia.RenderTests\TestRenderRoot.cs" Link="Infrastructure\TestRenderRoot.cs" />
    <Compile Include="..\Avalonia.RenderTests\ManualRenderTimer.cs" Link="Infrastructure\ManualRenderTimer.cs" />
  </ItemGroup>
  <ItemGroup>
    <!-- Deterministic text rendering: SVG test content references this font via
         a resm: font-family URI. -->
    <EmbeddedResource Include="..\Avalonia.RenderTests\Assets\NotoMono-Regular.ttf" Link="Assets\NotoMono-Regular.ttf" />
    <!-- The resvg corpus' bundled fonts (OFL, see the LICENSE files in Assets):
         registered as a font collection so corpus tests resolve their plain
         family names deterministically on every machine. -->
    <EmbeddedResource Include="Assets\NotoSans-Regular.ttf" />
    <EmbeddedResource Include="Assets\NotoColorEmoji.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-Bold.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-Italic.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-Light.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-Thin.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-Black.ttf" />
    <EmbeddedResource Include="Assets\NotoSans-ExtraCondensed.ttf" />
    <EmbeddedResource Include="Assets\Amiri-Regular.ttf" />
    <EmbeddedResource Include="Assets\MPLUS1p-Regular.ttf" />
    <EmbeddedResource Include="Assets\NotoSansDevanagari-Regular.ttf" />
    <EmbeddedResource Include="Assets\SourceSansPro-Regular.ttf" />
    <EmbeddedResource Include="Assets\NotoSerif-Regular.ttf" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Avalonia.Base\Avalonia.Base.csproj" />
    <ProjectReference Include="..\..\src\Avalonia.Controls\Avalonia.Controls.csproj" />
    <ProjectReference Include="..\..\src\Avalonia.Svg\Avalonia.Svg.csproj" />
    <ProjectReference Include="..\..\src\Skia\Avalonia.Skia\Avalonia.Skia.csproj" />
    <ProjectReference Include="..\Avalonia.UnitTests\Avalonia.UnitTests.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" />
    <PackageReference Include="System.Reactive" />
  </ItemGroup>
  <Import Project="..\..\build\XUnit.props" />
  <Import Project="..\..\build\SkiaSharp.props" />
  <Import Project="..\..\build\SharedVersion.props" />
  <Import Project="..\..\build\NullableEnable.props" />
</Project>
